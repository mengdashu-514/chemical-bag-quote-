.page{background:#f5f5f5;min-height:100vh;padding:40rpx 32rpx}.header{margin-bottom:40rpx;text-align:center}.header .title{color:#1a1a2e;display:block;font-size:40rpx;font-weight:600}.header .subtitle{color:#888;display:block;font-size:28rpx;margin-top:8rpx}.card{background:#fff;border-radius:16rpx;-webkit-box-shadow:0 2rpx 8rpx rgba(0,0,0,.06);box-shadow:0 2rpx 8rpx rgba(0,0,0,.06);margin-bottom:24rpx;padding:32rpx}.field{margin-bottom:32rpx}.field:last-child{margin-bottom:0}.field .label{color:#333;display:block;font-size:28rpx;font-weight:500;margin-bottom:16rpx}.picker-display{background:#fafafa;border:2rpx solid #ddd;border-radius:12rpx;color:#333;font-size:32rpx;height:88rpx;line-height:88rpx;padding:0 24rpx}.picker-display Text{color:#333}.input{background:#fafafa;border:2rpx solid #ddd;border-radius:12rpx;font-size:32rpx;height:88rpx;padding:0 24rpx}.result-card{background:#fff;border-radius:16rpx;-webkit-box-shadow:0 2rpx 8rpx rgba(0,0,0,.06);box-shadow:0 2rpx 8rpx rgba(0,0,0,.06);padding:32rpx}.price-row{-webkit-align-items:baseline;display:-webkit-flex;display:-ms-flexbox;display:-webkit-box;display:flex;-ms-flex-align:baseline;align-items:baseline;margin-bottom:16rpx}.price-label{color:#888;font-size:28rpx;margin-right:12rpx}.price-value{color:#1a1a2e;font-size:52rpx;font-weight:600}.price-value-lg{color:#1a1a2e;font-size:44rpx;font-weight:600}.price-unit{color:#888;font-size:28rpx;margin-left:8rpx}.calc-hint{color:#aaa;font-size:24rpx;margin-left:12rpx}.hint{color:#888;display:block;font-size:28rpx;padding:20rpx 0;text-align:center}.error-text{color:#e53e3e;display:block;font-size:28rpx;padding:20rpx 0;text-align:center}.warning{color:#e53e3e;display:block;font-size:28rpx;font-weight:500;margin-bottom:16rpx}.moq-text{color:#888;display:block;font-size:24rpx;margin-bottom:12rpx}.remark-text{color:#888;display:block;font-size:24rpx;margin-bottom:12rpx}.copy-btn{background:#1e3a5f!important;border:none;border-radius:12rpx;color:#fff!important;font-size:32rpx;height:88rpx;line-height:88rpx;margin-top:24rpx}.copy-btn::after{border:none}