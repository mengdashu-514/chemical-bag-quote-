# =====================================================================
# 化工包装袋报价系统 - 环境变量模板
# 用法：cp .env.example .env  并按需修改
# =====================================================================

# --- 数据库 ---
# 开发期：SQLite
DATABASE_URL="file:./dev.db"
# 生产期示例（PostgreSQL）：
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public"

# --- 鉴权 ---
# 用于签发后台 session cookie，必须 ≥ 32 字符随机串
# 生成方式： openssl rand -base64 32
SESSION_SECRET="please-change-me-to-a-random-32-char-string-aaaaa"

# --- 应用 ---
# 站点公开 URL（用于生成分享链接等），无尾斜杠
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
